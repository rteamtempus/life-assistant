# ============================================================
# Life Assistant — environment template
#
# Two distinct homes for config (handoff §6: keys server-side only):
#
#   1. CLIENT (Angular)  — public, client-safe values only.
#      These go in src/environments/environment*.ts, NOT here. The anon key is
#      safe to ship because RLS gates everything.
#        supabaseUrl      = Supabase → Project Settings → API → Project URL
#        supabaseAnonKey  = Supabase → Project Settings → API → anon public key
#
#   2. EDGE FUNCTION SECRETS  — privileged keys, set on Supabase, never shipped.
#      Set with:  npx supabase secrets set --env-file ./.env
#      (Copy this file to .env, fill it in, and keep .env gitignored.)
# ============================================================

# --- Gemini: powers EVERYTHING generative + transcription + embeddings —
#     structuring, nightly + weekly summaries, the urge coach, transcribe/stt,
#     and semantic-recall embeddings. One key (Google AI Studio). ---
GEMINI_API_KEY=

# --- Google Cloud TTS (Chirp 3 HD) for the urge-coach voice — §5 ---
# A Google Cloud API key with the Text-to-Speech API enabled. This can be the
# SAME key as GEMINI_API_KEY if that key's Cloud project has both APIs enabled.
GOOGLE_TTS_API_KEY=

# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected into Edge Functions
# automatically by the Supabase runtime — do not set them by hand.
